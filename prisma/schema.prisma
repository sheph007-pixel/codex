generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── AUTH & USER ───────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  displayName     String?  @map("display_name")
  avatarUrl       String?  @map("avatar_url")
  microsoftId     String?  @unique @map("microsoft_id")
  supabaseAuthId  String?  @unique @map("supabase_auth_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  emailAccounts   EmailAccount[]
  crmContacts     CrmContact[]
  deals           Deal[]
  emailMessages   EmailMessage[]
  emailFolders    EmailFolder[]
  activities      Activity[]
  settings        UserSetting[]

  @@map("users")
}

// ─────────────────────── EMAIL ACCOUNTS ────────────────────────

model EmailAccount {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  email         String
  displayName   String?  @map("display_name")
  provider      String   @default("microsoft") // microsoft | google | imap
  accessToken   String?  @map("access_token")
  refreshToken  String?  @map("refresh_token")
  tokenExpiry   DateTime? @map("token_expiry")
  syncState     String?  @map("sync_state") // delta link for incremental sync
  lastSyncAt    DateTime? @map("last_sync_at")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders       EmailFolder[]
  messages      EmailMessage[]

  @@unique([userId, email])
  @@map("email_accounts")
}

// ─────────────────────── EMAIL FOLDERS ─────────────────────────

model EmailFolder {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  accountId     String   @map("account_id")
  parentId      String?  @map("parent_id")
  name          String
  type          String   @default("custom") // inbox | sent | drafts | deleted | junk | archive | notes | outbox | custom
  icon          String?
  color         String?
  sortOrder     Int      @default(0) @map("sort_order")
  unreadCount   Int      @default(0) @map("unread_count")
  totalCount    Int      @default(0) @map("total_count")
  isFavorite    Boolean  @default(false) @map("is_favorite")
  externalId    String?  @map("external_id") // Graph API / Gmail folder ID
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent        EmailFolder? @relation("FolderTree", fields: [parentId], references: [id])
  children      EmailFolder[] @relation("FolderTree")
  messages      EmailMessage[]

  @@index([userId, accountId])
  @@index([parentId])
  @@map("email_folders")
}

// ─────────────────────── EMAIL MESSAGES ────────────────────────

model EmailMessage {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  accountId       String   @map("account_id")
  folderId        String   @map("folder_id")
  externalId      String?  @map("external_id") // Graph API / Gmail message ID
  conversationId  String?  @map("conversation_id")
  internetMsgId   String?  @map("internet_message_id")

  fromName        String?  @map("from_name")
  fromEmail       String   @map("from_email")
  toRecipients    Json     @default("[]") @map("to_recipients")    // [{name, email}]
  ccRecipients    Json     @default("[]") @map("cc_recipients")
  bccRecipients   Json     @default("[]") @map("bcc_recipients")

  subject         String   @default("")
  preview         String   @default("")
  bodyHtml        String?  @map("body_html")
  bodyText        String?  @map("body_text")

  sentAt          DateTime? @map("sent_at")
  receivedAt      DateTime  @map("received_at")
  isRead          Boolean   @default(false) @map("is_read")
  isFlagged       Boolean   @default(false) @map("is_flagged")
  isDraft         Boolean   @default(false) @map("is_draft")
  importance      String    @default("normal") // low | normal | high
  hasAttachments  Boolean   @default(false) @map("has_attachments")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder          EmailFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  attachments     EmailAttachment[]

  @@index([userId, folderId, receivedAt(sort: Desc)])
  @@index([userId, accountId])
  @@index([fromEmail])
  @@index([conversationId])
  @@index([externalId])
  @@map("email_messages")
}

// ─────────────────────── ATTACHMENTS ──────────────────────────

model EmailAttachment {
  id          String   @id @default(cuid())
  messageId   String   @map("message_id")
  name        String
  contentType String   @map("content_type")
  size        Int      @default(0)
  externalId  String?  @map("external_id")
  url         String?
  createdAt   DateTime @default(now()) @map("created_at")

  message     EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("email_attachments")
}

// ─────────────────────── CRM CONTACTS ─────────────────────────

model CrmContact {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  email           String
  name            String?
  company         String?
  jobTitle        String?  @map("job_title")
  phone           String?
  avatarUrl       String?  @map("avatar_url")
  domain          String?
  type            String   @default("lead") // lead | contact | customer | vendor | partner
  status          String   @default("active") // active | inactive | archived
  source          String?  // email_scan | manual | import | api
  tags            Json     @default("[]")
  customFields    Json     @default("{}") @map("custom_fields")
  notes           String?
  lastContactedAt DateTime? @map("last_contacted_at")
  sentCount       Int       @default(0) @map("sent_count")
  receivedCount   Int       @default(0) @map("received_count")
  enrichment      Json      @default("{}") // AI-enriched data
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals           Deal[]
  activities      Activity[]

  @@unique([userId, email])
  @@index([userId, type])
  @@index([userId, domain])
  @@index([email])
  @@map("crm_contacts")
}

// ─────────────────────────── DEALS ────────────────────────────

model Deal {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  contactId     String   @map("contact_id")
  title         String
  value         Float?
  currency      String   @default("USD")
  stage         String   @default("lead") // lead | qualified | proposal | negotiation | closed_won | closed_lost
  probability   Int?     // 0-100
  expectedClose DateTime? @map("expected_close")
  closedAt      DateTime? @map("closed_at")
  notes         String?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact       CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  activities    Activity[]

  @@index([userId, stage])
  @@index([contactId])
  @@map("deals")
}

// ────────────────────── ACTIVITY TIMELINE ──────────────────────

model Activity {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  contactId   String?  @map("contact_id")
  dealId      String?  @map("deal_id")
  type        String   // email_sent | email_received | note | call | meeting | deal_update | task
  title       String
  description String?
  metadata    Json     @default("{}")
  occurredAt  DateTime @map("occurred_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal        Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([contactId])
  @@index([dealId])
  @@map("activities")
}

// ────────────────────── USER SETTINGS ─────────────────────────

model UserSetting {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  key       String
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_settings")
}
